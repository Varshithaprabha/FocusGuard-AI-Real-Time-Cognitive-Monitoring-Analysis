{
  "manifest_version": 3,
  "name": "Focus Mode Intervention",
  "version": "1.0",
  "description": "Blocks distracting websites when AI Study Planner detects you are in Focus Mode.",
  "permissions": [
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.twitter.com/*",
    "*://*.facebook.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.twitter.com/*", "*://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Focus Mode Sync"
  }
}
